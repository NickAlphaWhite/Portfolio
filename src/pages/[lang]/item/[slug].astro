---
import type { PortfolioItem } from "../../../types";
import { CATEGORY_LABELS } from "../../../types";
import Layout from "../../../components/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { ui } from "../../../i18n/ui";
import allItems from "../../../content/items/data.json";

const items = allItems as PortfolioItem[];

export async function getStaticPaths() {
  const fs = await import("node:fs");
  const path = await import("node:path");
  const filePath = path.join(process.cwd(), "src/content/items/data.json");
  const raw = fs.readFileSync(filePath, "utf-8");
  const data = JSON.parse(raw) as PortfolioItem[];
  return data.flatMap(item => [
    { params: { lang: "en", slug: item.id } },
    { params: { lang: "zh", slug: item.id } },
  ]);
}

const { lang, slug } = Astro.params as { lang: "en" | "zh"; slug: string };
const item = items.find(i => i.id === slug);

if (!item) {
  const notFoundBase = import.meta.env.BASE_URL.replace(/\/$/, "");
  return Astro.redirect(`${notFoundBase}/${lang}/`);
}

const t = (key: string) => ui[lang][key as keyof typeof ui.en] || key;
const title = lang === "zh" ? item.title_zh : item.title_en;
const desc = lang === "zh" ? item.description_zh : item.description_en;
const author = lang === "zh" ? item.author_name_zh : item.author_name_en;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Related: same category, excluding current
const related = items.filter(i => i.category === item.category && i.id !== item.id).slice(0, 4);
---

<Layout title={title} description={desc} {lang}>
  <Header />

  <main class="detail">
    <div class="container">
      <!-- Back link -->
      <a href={`${base}/${lang}/`} style="display:inline-flex;align-items:center;gap:6px;color:var(--text-secondary);font-size:var(--text-sm);margin-bottom:var(--space-lg);transition:color var(--duration-fast) var(--ease-out)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        {t("item.back")}
      </a>

      <div class="detail-grid">
        <!-- Image -->
        <div class="detail-image">
          {item.thumbnail ? (
            <img src={item.thumbnail} alt={title} style="width:100%" />
          ) : (
            <div class="skeleton" style="width:100%;aspect-ratio:1.5"></div>
          )}
        </div>

        <!-- Info -->
        <div class="detail-info">
          <h1 class="detail-title">{title}</h1>
          <p class="detail-author">{t("item.author")} {author}</p>
          <p class="detail-description">{desc}</p>

          <!-- Meta -->
          <div class="detail-meta">
            <div class="detail-meta-item">
              <span class="detail-meta-label">{t("item.institution")}</span>
              <span class="detail-meta-value">{item.institution}</span>
            </div>
            <div class="detail-meta-item">
              <span class="detail-meta-label">{t("item.program")}</span>
              <span class="detail-meta-value">{item.program}</span>
            </div>
            <div class="detail-meta-item">
              <span class="detail-meta-label">{t("item.year")}</span>
              <span class="detail-meta-value">{item.year}</span>
            </div>
          </div>

          <!-- Tags -->
          <div class="detail-tags">
            {item.tags.map(tag => (
              <span class="detail-tag">{tag.replace(/_/g, " ")}</span>
            ))}
          </div>

          <!-- Source link -->
          <div>
            <a href={item.source_url} target="_blank" rel="noopener noreferrer" class="detail-link">
              {t("item.source")}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Related -->
      {related.length > 0 && (
        <section style="margin-top:var(--space-4xl)">
          <h2 style="font-size:var(--text-2xl);font-weight:600;margin-bottom:var(--space-lg);letter-spacing:-0.01em">
            {t("item.related")}
          </h2>
          <div class="gallery-grid">
            {related.map(r => (
              <div data-category={r.category} data-institution={r.institution} data-search={`${r.title_en} ${r.author_name_en} ${r.tags.join(" ")}`}>
                <a
                  href={`${base}/${lang}/item/${r.id}`}
                  class="item-card card-hover"
                  data-category={r.category}
                  data-institution={r.institution}
                  data-search={`${r.title_en} ${r.title_zh} ${r.author_name_en} ${r.tags.join(" ")}`}
                >
                  <div class="item-card-image" style={`aspect-ratio: ${r.aspect_ratio || 1.5}`}>
                    {r.thumbnail ? (
                      <img src={r.thumbnail} alt={lang === "zh" ? r.title_zh : r.title_en} loading="lazy" decoding="async" width="400" height={Math.round(400 / r.aspect_ratio)} />
                    ) : (
                      <div class="skeleton" style="width:100%;height:100%"></div>
                    )}
                    <span class="item-card-badge">{CATEGORY_LABELS[r.category][lang]}</span>
                  </div>
                  <div class="item-card-body">
                    <h3 class="item-card-title">{lang === "zh" ? r.title_zh : r.title_en}</h3>
                    <p class="item-card-meta">{lang === "zh" ? r.author_name_zh : r.author_name_en} · {r.institution}</p>
                  </div>
                </a>
              </div>
            ))}
          </div>
        </section>
      )}
    </div>
  </main>

  <Footer />
</Layout>
