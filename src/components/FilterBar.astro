---
import { ui } from "../i18n/ui";
import { CATEGORY_LABELS } from "../types";
import type { Category } from "../types";

interface Props {
  lang: "en" | "zh";
  institutions: string[];
  activeCategory: string;
  activeInstitution: string;
}

const { lang, institutions, activeCategory, activeInstitution } = Astro.props;
const t = (key: string) => ui[lang][key as keyof typeof ui.en] || key;
const categories = Object.entries(CATEGORY_LABELS) as [Category, { en: string; zh: string }][];
---

<aside class="sidebar" id="sidebar">
  <div class="sidebar-inner">
    <!-- Search -->
    <div class="sidebar-search">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        type="search"
        id="hero-search-input"
        placeholder={t("search.placeholder")}
        autocomplete="off"
      />
    </div>

    <!-- Result count -->
    <div class="sidebar-count" id="result-count"></div>

    <!-- Categories -->
    <div class="sidebar-label">{t("filter.category")}</div>
    <div class="sidebar-chips" id="filter-chips">
      <button class="sidebar-chip active" data-category="all">{t("filter.all")}</button>
      {categories.map(([key, labels]) => (
        <button class="sidebar-chip" data-category={key}>{labels[lang]}</button>
      ))}
    </div>

    <!-- Institution -->
    <div class="sidebar-label">{t("filter.institution")}</div>
    <select id="institution-select" class="sidebar-select">
      <option value="all">{t("filter.all")}</option>
      {institutions.map(inst => (
        <option value={inst}>{inst}</option>
      ))}
    </select>
  </div>
</aside>

<script>
  const searchInput = (document.getElementById("hero-search-input") || document.getElementById("search-input")) as HTMLInputElement;
  const filterChips = document.getElementById("filter-chips")!;
  const institutionSelect = document.getElementById("institution-select") as HTMLSelectElement;
  const resultCount = document.getElementById("result-count")!;
  const gallery = document.querySelector(".gallery-grid") as HTMLElement;

  let currentCategory = "all";
  let currentInstitution = "all";
  let currentQuery = "";
  let allCards: HTMLElement[] = [];

  function init() {
    allCards = Array.from(gallery?.querySelectorAll(".item-card") || []);
    updateResults();

    searchInput?.addEventListener("input", () => {
      currentQuery = searchInput.value.toLowerCase().trim();
      updateResults();
    });

    filterChips?.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest(".sidebar-chip") as HTMLButtonElement;
      if (!btn) return;
      currentCategory = btn.dataset.category || "all";
      filterChips.querySelectorAll(".sidebar-chip").forEach(c => c.classList.remove("active"));
      btn.classList.add("active");
      updateResults();
    });

    institutionSelect?.addEventListener("change", () => {
      currentInstitution = institutionSelect.value;
      updateResults();
    });
  }

  function updateResults() {
    let visible = 0;
    allCards.forEach(card => {
      const cat = card.dataset.category || "";
      const inst = card.dataset.institution || "";
      const searchText = (card.dataset.search || "").toLowerCase();

      const catMatch = currentCategory === "all" || cat === currentCategory;
      const instMatch = currentInstitution === "all" || inst === currentInstitution;
      const queryMatch = !currentQuery || searchText.includes(currentQuery);

      if (catMatch && instMatch && queryMatch) {
        card.style.display = "";
        visible++;
      } else {
        card.style.display = "none";
      }
    });

    if (resultCount) {
      resultCount.textContent = `${visible} / ${allCards.length}`;
    }

    const empty = document.getElementById("empty-state");
    if (empty) {
      empty.style.display = visible === 0 ? "" : "none";
    }
  }

  init();
</script>

<style>
  .layout { display: flex; max-width: 1440px; margin: 0 auto; padding: 0 24px; gap: 32px; }
  .layout-content { flex: 1; min-width: 0; }
  .sidebar { width: 200px; flex-shrink: 0; padding-top: 32px; }
  .sidebar-inner { position: sticky; top: 68px; display: flex; flex-direction: column; gap: 8px; }
  .sidebar-search { position: relative; }
  .sidebar-search svg { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text-tertiary); z-index: 1; }
  .sidebar-search input { width: 100%; height: 36px; padding: 0 12px 0 30px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-secondary); color: var(--text-primary); font-size: 13px; outline: none; }
  .sidebar-search input:focus { border-color: var(--accent); }
  .sidebar-count { font-size: 12px; color: var(--text-tertiary); }
  .sidebar-label { font-size: 11px; font-weight: 600; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.04em; margin-top: 8px; }
  .sidebar-chips { display: flex; flex-direction: column; gap: 3px; }
  .sidebar-chip { width: 100%; text-align: left; padding: 5px 10px; border-radius: 6px; font-size: 13px; font-weight: 500; color: var(--text-secondary); transition: all 0.15s; cursor: pointer; border: none; background: none; font-family: inherit; }
  .sidebar-chip:hover { color: var(--text-primary); background: var(--bg-secondary); }
  .sidebar-chip.active { color: #fff; background: var(--accent); }
  .sidebar-select { width: 100%; padding: 6px 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary); font-size: 13px; cursor: pointer; outline: none; }
  .sidebar-select:focus { border-color: var(--accent); }
  .filter-bar { display: none; }
  @media (max-width: 768px) {
    .layout { flex-direction: column; }
    .sidebar { width: 100%; padding-top: 16px; }
    .sidebar-inner { position: static; flex-direction: row; flex-wrap: wrap; align-items: center; gap: 6px; }
    .sidebar-search { flex: 1; min-width: 120px; }
    .sidebar-label { display: none; }
    .sidebar-chips { flex-direction: row; flex-wrap: wrap; }
    .sidebar-chip { width: auto; }
    .sidebar-select { width: auto; }
    .sidebar-count { width: 100%; }
  }
</style>
